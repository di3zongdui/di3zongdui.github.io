<footer class="site-footer">
  <div class="footer-container">
    <!-- About Section -->
    <div class="footer-section footer-about">
      <h3 class="footer-title">{{ site.author.name }}</h3>
      <p class="footer-bio">{{ site.author.bio }}</p>
      <p class="footer-company">{{ site.custom.company }} | {{ site.author.title }}</p>
    </div>
    
    <!-- Contact Section -->
    <div class="footer-section footer-contact">
      <h3 class="footer-title">联系咨询</h3>
      <ul class="footer-links">
        <li>
          <a href="mailto:{{ site.author.email }}">
            <span class="icon">📧</span> {{ site.author.email }}
          </a>
        </li>
        <li>
          <a href="mailto:{{ site.author.email_alt }}">
            <span class="icon">📧</span> {{ site.author.email_alt }}
          </a>
        </li>
        <li>
          <a href="tel:{{ site.custom.hotline }}">
            <span class="icon">📱</span> {{ site.custom.hotline }}
          </a>
        </li>
      </ul>
    </div>
    
    <!-- Social Section -->
    <div class="footer-section footer-social">
      <h3 class="footer-title">关注我</h3>
      <ul class="social-links">
        <li>
          <a href="{{ site.social.linkedin }}" target="_blank" rel="noopener noreferrer">
            <span class="icon">💼</span> LinkedIn
          </a>
        </li>
        <li>
          <a href="{{ site.social.github }}" target="_blank" rel="noopener noreferrer">
            <span class="icon">💻</span> GitHub
          </a>
        </li>
        <li>
          <a href="{{ site.social.twitter }}" target="_blank" rel="noopener noreferrer">
            <span class="icon">🐦</span> Twitter
          </a>
        </li>
        <li>
          <a href="#" class="wechat-link">
            <span class="icon">💬</span> 微信公众号
          </a>
          {% if site.custom.wechat_qrcode %}
          <div class="wechat-qr-popup">
            <img src="{{ site.custom.wechat_qrcode | relative_url }}" alt="微信公众号" class="wechat-qr">
            <p>搜索：{{ site.social.wechat }}</p>
          </div>
          {% endif %}
        </li>
      </ul>
    </div>
    
    <!-- Services Section -->
    <div class="footer-section footer-services">
      <h3 class="footer-title">核心服务</h3>
      <ul class="footer-links">
        <li><a href="/">AI人才战略</a></li>
        <li><a href="/">AI转型咨询</a></li>
        <li><a href="/training/">AI战略官培训</a></li>
        <li><a href="/">AI组织培训</a></li>
      </ul>
    </div>
  </div>
  
  <!-- Copyright -->
  <div class="footer-bottom">
    <p class="copyright">
      © {{ "now" | date: "%Y" }} {{ site.author.name }} | 乔治AI观察
    </p>
    <p class="footer-meta">
      <a href="{{ site.social.github }}" target="_blank">GitHub @{{ site.custom.username }}</a>
      · Powered by Jekyll
    </p>
  </div>
</footer>
